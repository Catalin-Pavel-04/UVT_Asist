{
  "name": "UVT Asist",
  "description": "Asistent AI pentru studenții UVT: răspunsuri scurte, surse și context de sesiune.",
  "version": "0.2.0",
  "manifest_version": 3,
  "action": {
    "default_title": "UVT Asist",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
