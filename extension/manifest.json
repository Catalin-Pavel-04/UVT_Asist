{
  "name": "UVT Asist",
  "description": "Asistent UVT cu RAG local peste surse oficiale, Ollama si Qdrant",
  "version": "0.5.0",
  "manifest_version": 3,
  "action": {
    "default_title": "UVT Asist",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "http://localhost:5000/*"
  ]
}
