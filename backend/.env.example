GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
CACHE_REFRESH_SECONDS=10800
CACHE_DISCOVERY_LINKS=30
CACHE_MAX_URLS_PER_FACULTY=120
CACHE_MAX_HTML_PAGES_PER_FACULTY=50
CACHE_MAX_CRAWL_DEPTH=3
CACHE_PAGE_FETCH_WORKERS=8
CACHE_FACULTY_REFRESH_WORKERS=4
ENABLE_PADDLE_OCR=false
PADDLE_OCR_PYTHON=
PADDLE_OCR_LANG=ro
PADDLE_OCR_TIMEOUT=120
PADDLE_OCR_MIN_TEXT_CHARS=120
PADDLE_OCR_MAX_PAGES=6
