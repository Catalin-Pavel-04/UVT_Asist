OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_GENERATION_MODEL=qwen3:4b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TEMPERATURE=0.15
OLLAMA_TOP_P=0.9
OLLAMA_NUM_PREDICT=350
OLLAMA_REQUEST_TIMEOUT_SECONDS=120
OLLAMA_EMBED_TIMEOUT_SECONDS=120
OLLAMA_MAX_EMBED_TEXT_CHARS=6000
OLLAMA_EMBED_BATCH_SIZE=8
OLLAMA_QUERY_ANALYSIS_ENABLED=true
OLLAMA_QUERY_ANALYSIS_TIMEOUT_SECONDS=6
OLLAMA_QUERY_ANALYSIS_MAX_KEYWORDS=12
QUERY_REWRITE_CACHE_TTL=600

QDRANT_URL=http://127.0.0.1:6333
QDRANT_PATH=
QDRANT_COLLECTION=uvt_asist_chunks
QDRANT_TIMEOUT_SECONDS=30
QDRANT_UPSERT_BATCH_SIZE=64

# Runtime answers use only the local JSON/Qdrant index. Live verification was disabled
# because the index is treated as the current source snapshot for the thesis demo.
LIVE_VERIFY_ENABLED=false
LIVE_VERIFY_LIMIT=0
LIVE_FETCH_MAX_TEXT_LENGTH=16000
LIVE_FETCH_MAX_PDF_PAGES=12
LIVE_FETCH_CACHE_TTL=300
VERIFICATION_CACHE_TTL=1800
VERIFICATION_FETCH_WORKERS=3
CHAT_RESPONSE_CACHE_TTL=300
CHAT_CACHE_VERSION=2026-06-01-rag-v3
MAX_QUESTION_CHARS=1200
MIN_GENERATION_CONFIDENCE_SCORE=35
MAX_FEEDBACK_TEXT_CHARS=4000
MAX_FEEDBACK_SOURCES=6

# Full rebuild poate dura foarte mult pe index mare.
STARTUP_REBUILD_INDEX=false
STARTUP_REBUILD_FULL_SITE=true
STARTUP_USE_SITEMAPS=true
STARTUP_SKIP_VECTOR_INDEX=false
STARTUP_MAX_URLS_PER_FACULTY=0
STARTUP_MAX_DEPTH=5
STARTUP_MAX_LINKS_PER_PAGE=150
STARTUP_FETCH_WORKERS=12
STARTUP_TERMINAL_PROGRESS=true
INDEX_MAX_PAGE_TEXT_CHARS=24000
INDEX_MAX_CHUNKS_PER_PAGE=32
INDEX_HTML_FETCH_TEXT_CHARS=24000
INDEX_DOCUMENT_MAX_PAGE_TEXT_CHARS=120000
INDEX_DOCUMENT_MAX_CHUNKS_PER_PAGE=140
INDEX_DOCUMENT_FETCH_TEXT_CHARS=120000
INDEX_DOCUMENT_FETCH_PDF_PAGES=80
INDEX_MAX_CHUNK_WORD_CHARS=1000

VECTOR_SEARCH_LIMIT=18
SEMANTIC_SCORE_WEIGHT=58
VECTOR_LEXICAL_BACKFILL_ENABLED=false
FLASK_DEBUG=false

ALLOWED_CORS_ORIGINS=http://127.0.0.1:5000,http://localhost:5000

ENABLE_PADDLE_OCR=false
PADDLE_OCR_PYTHON=
PADDLE_OCR_LANG=ro
PADDLE_OCR_TIMEOUT=120
PADDLE_OCR_MIN_TEXT_CHARS=120
PADDLE_OCR_MAX_PAGES=6
