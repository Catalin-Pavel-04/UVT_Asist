OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_GENERATION_MODEL=qwen3:4b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TEMPERATURE=0.15
OLLAMA_TOP_P=0.9
OLLAMA_NUM_PREDICT=700
OLLAMA_EMBED_BATCH_SIZE=8

QDRANT_URL=http://127.0.0.1:6333
QDRANT_PATH=
QDRANT_COLLECTION=uvt_asist_chunks
QDRANT_TIMEOUT_SECONDS=30
QDRANT_UPSERT_BATCH_SIZE=64

LIVE_VERIFY_LIMIT=2
LIVE_FETCH_CACHE_TTL=300
VERIFICATION_CACHE_TTL=1800
VERIFICATION_FETCH_WORKERS=3
CHAT_RESPONSE_CACHE_TTL=300

VECTOR_SEARCH_LIMIT=18
SEMANTIC_SCORE_WEIGHT=58
FLASK_DEBUG=false

ENABLE_PADDLE_OCR=false
PADDLE_OCR_PYTHON=
PADDLE_OCR_LANG=ro
PADDLE_OCR_TIMEOUT=120
PADDLE_OCR_MIN_TEXT_CHARS=120
PADDLE_OCR_MAX_PAGES=6
